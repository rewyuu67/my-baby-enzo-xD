<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>I LOVE MY BABY ENZO</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    width:100%;
    height:100vh;
    overflow:hidden;
    background:black;
    display:flex;
    justify-content:center;
    align-items:center;
    font-family:Arial, sans-serif;
}

/* MAIN TEXT */
.text{
    position:relative;
    font-size:90px;
    font-weight:bold;
    color:white;
    text-align:center;
    letter-spacing:6px;
    text-transform:uppercase;

    animation: glow 2s ease-in-out infinite alternate;
}

/* GLOW BEHIND TEXT */
.text::before{
    content:"I LOVE MY BABY ENZO";
    position:absolute;
    left:0;
    top:0;
    z-index:-1;

    color:#ff6699;

    filter:blur(35px);
}

/* TEXT GLOW */
@keyframes glow{
    from{
        text-shadow:
        0 0 10px #ff6699,
        0 0 20px #ff6699,
        0 0 40px #ff6699,
        0 0 80px #ff6699;
    }

    to{
        text-shadow:
        0 0 20px #ff9966,
        0 0 40px #ff9966,
        0 0 80px #ff9966,
        0 0 120px #ff9966;
    }
}

/* HEARTS CONTAINER */
.hearts{
    position:absolute;
    width:100%;
    height:100%;
    overflow:hidden;
}

/* HEART STYLE */
.heart{
    position:absolute;
    bottom:-120px;

    font-size:80px;

    animation: float linear forwards;

    user-select:none;
}

/* FLOATING HEART ANIMATION */
@keyframes float{
    0%{
        transform:translateY(0) scale(0.8);
        opacity:0;
    }

    10%{
        opacity:1;
    }

    100%{
        transform:translateY(-130vh) scale(1.5);
        opacity:0;
    }
}

/* MOBILE */
@media (max-width:768px){

    .text{
        font-size:40px;
        padding:20px;
    }

    .heart{
        font-size:45px;
    }
}
</style>
</head>

<body>

<div class="hearts"></div>

<div class="text">
    I LOVE MY BABY ENZO
</div>

<script>

const heartsContainer = document.querySelector('.hearts');

/* HEART COLORS */
const colors = [
    "#ff4d4d", // red
    "#ff944d", // orange
    "#ff66b3", // pink
    "#ff3366", // deep pink
    "#ff9966"  // soft orange
];

function createHeart(){

    const heart = document.createElement('div');

    heart.classList.add('heart');

    heart.innerHTML = '❤';

    /* RANDOM POSITION */
    heart.style.left = Math.random() * 100 + 'vw';

    /* RANDOM SIZE */
    const size = 60 + Math.random() * 70;
    heart.style.fontSize = size + 'px';

    /* RANDOM SPEED */
    heart.style.animationDuration =
        (4 + Math.random() * 5) + 's';

    /* RANDOM COLOR */
    const color =
        colors[Math.floor(Math.random() * colors.length)];

    heart.style.color = color;

    /* GLOW EFFECT */
    heart.style.textShadow = `
        0 0 10px ${color},
        0 0 20px ${color},
        0 0 40px ${color},
        0 0 80px ${color}
    `;

    heartsContainer.appendChild(heart);

    setTimeout(() => {
        heart.remove();
    }, 9000);
}

/* CREATE HEARTS */
setInterval(createHeart, 100);

</script>

</body>
</html>
